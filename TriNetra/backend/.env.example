# Copy this file to ".env" in the same folder and fill in your real key(s).
# Never commit the real ".env" file — it's already covered by .gitignore.

# Which provider to use for the AI-enhanced insights features: "openai" or "openrouter"
LLM_PROVIDER=openai

# Required if LLM_PROVIDER=openai. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Required if LLM_PROVIDER=openrouter. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
